<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd" >

<hibernate-mapping package="@MODULE_PACKAGE@.model">

	<class name="XformCohort" table="cohort">
	
		<id name="cohortId" type="int" column="cohort_id">
				<generator class="assigned" />
		</id>

		<property name="name" type="java.lang.String" column="name" not-null="true" length="255" />
		
	</class>
	
</hibernate-mapping>
